# === Ship ONLY the core DSAT method files from sat/ ===
# (excludes kegg variants, attention visualization, alt data loaders, tests, scratch)
sat/*
!sat/__init__.py
!sat/train.py
!sat/model.py
!sat/models.py
!sat/layers.py
!sat/gnn_layers.py
!sat/position_encoding.py
!sat/utils.py

